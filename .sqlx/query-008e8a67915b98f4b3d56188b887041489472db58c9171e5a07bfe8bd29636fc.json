  "query": "\n        SELECT \n            r.id, r.user_id, r.original_post_id, r.content_rendered_html,\n            r.echo_count, r.created_at, r.edited_at, r.deleted_at, r.is_spam,\n            u.username\n        FROM refracts r\n        JOIN users u ON r.user_id = u.id\n        WHERE r.id = $1 AND r.is_spam = false\n        ",

  "query": "\n        SELECT \n            p.id, p.slug, p.user_id, p.title, p.content_rendered_html,\n            p.created_at, p.deleted_at,\n            u.username\n        FROM posts p\n        JOIN users u ON p.user_id = u.id\n        WHERE p.id = $1\n        ",

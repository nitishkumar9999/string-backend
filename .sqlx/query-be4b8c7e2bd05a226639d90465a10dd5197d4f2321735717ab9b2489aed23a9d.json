{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT p.id, p.user_id, p.title, p.content_rendered_html, p.slug, p.is_spam,\n                   p.echo_count, p.refract_count, p.comment_count,\n                   p.created_at, p.edited_at, u.username\n            FROM posts p\n            JOIN users u ON p.user_id = u.id\n            WHERE p.deleted_at IS NULL AND p.is_spam = false AND p.created_at < $1\n            ORDER BY p.created_at DESC\n            LIMIT $2\n            ",
